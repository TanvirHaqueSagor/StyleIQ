# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # Silence all third-party pod warnings (firebase, share_plus, etc.)
      config.build_settings['WARNING_CFLAGS'] = '-w'
      config.build_settings['SWIFT_SUPPRESS_WARNINGS'] = 'YES'
      # Fix: RecaptchaInterop uses double-quoted includes in framework headers
      config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'

      # Raise any pod's minimum deployment target to 16.0
      min_target = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET']
      if min_target.to_f < 16.0
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      end

      # Enable the specific permissions needed by permission_handler.
      # Without these macros the permission is stripped from the binary
      # and never appears in iOS Settings.
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_CAMERA=1',
        'PERMISSION_PHOTOS=1',
        'PERMISSION_PHOTOS_ADD_ONLY=1',
      ]

      # Fix: 0xe8008014 invalid signature on objective_c.framework (and any
      # other XCFramework slices) when deploying to a physical device.
      # Disable pod-level code signing so Xcode re-signs every embedded
      # framework with the active provisioning profile during the final
      # "Embed & Sign" step.
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end

  # Re-enable signing for the main Runner target — it must be signed.
  installer.pods_project.targets.each do |target|
    next unless target.name == 'Runner'
    target.build_configurations.each do |config|
      config.build_settings.delete('CODE_SIGNING_ALLOWED')
    end
  end
end
